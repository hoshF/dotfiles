{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "instructions": ["/Users/hoshf/.codex/AGENTS.md"],

  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/hoshf"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    }
  },

  "permission": {
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "pnpm *": "allow",
      "yarn *": "allow",
      "cargo *": "allow",
      "go *": "allow",
      "brew *": "allow",
      "ssh *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "which *": "allow",
      "echo *": "allow",
      "pwd *": "allow",
      "env *": "allow",
      "date *": "allow",
      "uname *": "allow"
    },
    "external_directory": {
      "*": "allow",
      "~/secrets/**": "deny",
      "~/.ssh/**": "deny"
    }
  }
}

#!/bin/bash
# .yadm/bootstrap

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Config
YADM_DIR="$HOME/.yadm"
PACKAGE_FILE="$YADM_DIR/packages.yaml"
LOG_FILE="/tmp/bootstrap-$(date +%Y%m%d-%H%M%S).log"

exec > >(tee -a "$LOG_FILE") 2>&1
echo "Bootstrap log: $LOG_FILE"

# ========================
#  Check/Install yq (via pacman)
# ========================
check_yq() {
    if command -v yq &> /dev/null; then
        echo -e "${GREEN}✓ yq already installed${NC}"
        return 0
    fi
    
    echo -e "${YELLOW}yq not found, installing via pacman...${NC}"
    
    # Check if pacman is available (should be on Arch Linux)
    if ! command -v pacman &> /dev/null; then
        echo -e "${RED}Error: pacman not found. This script requires Arch Linux.${NC}"
        exit 1
    fi
    
    # Install yq from pacman
    sudo pacman -S --noconfirm yq
    
    if ! command -v yq &> /dev/null; then
        echo -e "${RED}Failed to install yq${NC}"
        exit 1
    fi
    
    echo -e "${GREEN}✓ yq installed${NC}"
}

# ========================
#  Read packages from YAML
# ========================
get_packages() {
    local category="$1"
    local subcategory="$2"
    
    if [ -n "$subcategory" ]; then
        yq ".$category.$subcategory[]" "$PACKAGE_FILE" 2>/dev/null || true
    else
        yq ".$category[]" "$PACKAGE_FILE" 2>/dev/null || true
    fi
}

# ========================
#  Installation functions
# ========================
install_pacman_packages() {
    echo -e "${GREEN}[1/4] Installing Pacman packages${NC}"
    
    # Update system
    sudo pacman -Syu --noconfirm
    
    # Collect all packages
    local packages=()
    
    # Add yq to packages if not already installed (but it should be installed by check_yq)
    # This ensures yq gets updated with system packages
    
    # Get all categories except 'desktop' and 'aur'
    for category in core ime viewers latex fonts audio formatters common; do
        while IFS= read -r pkg; do
            [ -n "$pkg" ] && packages+=("$pkg")
        done < <(get_packages "pacman" "$category")
    done
    
    # Add desktop packages if selected
    if [ -n "$DESKTOP_ENV" ] && [ "$DESKTOP_ENV" != "none" ]; then
        echo -e "${BLUE}Adding $DESKTOP_ENV packages...${NC}"
        while IFS= read -r pkg; do
            [ -n "$pkg" ] && packages+=("$pkg")
        done < <(get_packages "pacman" "desktop" "$DESKTOP_ENV")
    fi
    
    echo -e "${BLUE}Installing ${#packages[@]} packages...${NC}"
    sudo pacman -S --noconfirm --needed "${packages[@]}"
    
    echo -e "${GREEN}✓ Pacman packages installed${NC}"
}

install_aur_packages() {
    echo -e "${GREEN}[2/4] Installing AUR packages${NC}"
    
    if ! command -v yay &> /dev/null; then
        echo -e "${YELLOW}Installing yay first...${NC}"
        local build_dir="/tmp/yay-build"
        mkdir -p "$build_dir"
        cd "$build_dir"
        git clone https://aur.archlinux.org/yay.git
        cd yay
        makepkg -si --noconfirm
        cd "$HOME"
        rm -rf "$build_dir"
    fi
    
    # Collect AUR packages
    local aur_packages=()
    for category in fonts ime tools; do
        while IFS= read -r pkg; do
            [ -n "$pkg" ] && aur_packages+=("$pkg")
        done < <(get_packages "aur" "$category")
    done
    
    if [ ${#aur_packages[@]} -gt 0 ]; then
        echo -e "${BLUE}Installing AUR packages...${NC}"
        yay -S --noconfirm --needed "${aur_packages[@]}"
    fi
    
    echo -e "${GREEN}✓ AUR packages installed${NC}"
}

install_go_packages() {
    echo -e "${GREEN}[3/4] Installing Go packages${NC}"
    
    if ! command -v go &> /dev/null; then
        echo -e "${YELLOW}Go not installed, skipping${NC}"
        return
    fi
    
    local gopath="$HOME/go"
    export GOPATH="$gopath"
    export PATH="$PATH:$gopath/bin"
    export GOPROXY=https://goproxy.cn,direct
    
    while IFS= read -r pkg; do
        [ -z "$pkg" ] && continue
        local name=$(basename "$pkg" | cut -d'@' -f1)
        echo -e "${BLUE}Installing: $name${NC}"
        go install "$pkg" || echo -e "${YELLOW}Failed: $pkg${NC}"
    done < <(get_packages "go")
    
    echo -e "${GREEN}✓ Go packages installed${NC}"
}

update_font_cache() {
    echo -e "${GREEN}[4/4] Updating font cache${NC}"
    fc-cache -fv > /dev/null 2>&1 && echo -e "${GREEN}✓ Font cache updated${NC}"
}

# ========================
#  Main menu
# ========================
show_menu() {
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}   Bootstrap Installation${NC}"
    echo -e "${CYAN}================================${NC}"
    
    echo -e "${YELLOW}Select desktop environment:${NC}"
    echo "1) Sway"
    echo "2) Hyprland"
    echo "3) None"
    read -p "Choice [3]: " de_choice
    
    case ${de_choice:-3} in
        1) DESKTOP_ENV="sway" ;;
        2) DESKTOP_ENV="hyprland" ;;
        *) DESKTOP_ENV="none" ;;
    esac
    
    echo -e "${GREEN}Selected: $DESKTOP_ENV${NC}"
    echo ""
    
    read -p "Proceed with installation? (y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Installation cancelled"
        exit 0
    fi
}

# ========================
#  Main
# ========================
main() {
    show_menu
    check_yq
    install_pacman_packages
    install_aur_packages
    install_go_packages
    update_font_cache
    
    echo -e "${GREEN}✓ Bootstrap complete!${NC}"
    echo -e "${BLUE}Log saved to: $LOG_FILE${NC}"
}

main

#!/bin/bash
# bootstrap

set -e

# ========================
#  Colors & Config
# ========================
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

YADM_DIR="$(dirname "$(realpath "$0")")"
PACKAGE_FILE="$YADM_DIR/packages.yaml"
LOG_FILE="/tmp/bootstrap-$(date +%Y%m%d-%H%M%S).log"

PACMAN_CATEGORIES=("core" "cli_tools" "sway_desktop" "ime" "viewers" "latex" "fonts" "audio" "services" "security")
AUR_CATEGORIES=("browser" "fonts" "ime" "tools" "security")

exec > >(tee -a "$LOG_FILE") 2>&1
echo "Bootstrap log: $LOG_FILE"
echo "YADM Directory: $YADM_DIR"

# ========================
#  Check/Install yq
# ========================
check_yq() {
    if command -v yq &> /dev/null; then
        echo -e "${GREEN}✓ yq already installed${NC}"
        return 0
    fi
    echo -e "${YELLOW}yq not found, installing via pacman...${NC}"
    sudo pacman -Sy --noconfirm yq
}

get_packages() {
    local repo="$1"
    local category="$2"
    # 读取 yaml 内容
    yq ".$repo.$category[]" "$PACKAGE_FILE" 2>/dev/null || true
}

# ========================
#  1. Graphics Driver Auto-Detection
# ========================
install_drivers() {
    echo -e "${GREEN}[1/6] Detecting and installing graphics drivers...${NC}"
    local GPU_INFO=$(lspci | grep -i 'vga\|3d\|display')
    local DRIVER_PKGS=()
    local IS_NVIDIA=false

    if echo "$GPU_INFO" | grep -iq 'amd\|radeon'; then
        echo -e "${BLUE}Detected AMD GPU.${NC}"
        DRIVER_PKGS+=("mesa" "vulkan-radeon" "xf86-video-amdgpu")
    fi
    
    if echo "$GPU_INFO" | grep -iq 'intel'; then
        echo -e "${BLUE}Detected Intel GPU.${NC}"
        DRIVER_PKGS+=("mesa" "vulkan-intel" "intel-media-driver")
    fi
    
    if echo "$GPU_INFO" | grep -iq 'nvidia'; then
        echo -e "${BLUE}Detected NVIDIA GPU.${NC}"
        DRIVER_PKGS+=("nvidia-dkms" "nvidia-utils" "egl-wayland" "linux-headers")
        IS_NVIDIA=true
    fi

    if [ ${#DRIVER_PKGS[@]} -eq 0 ]; then
        echo -e "${YELLOW}No specific GPU detected. Defaulting to mesa.${NC}"
        DRIVER_PKGS+=("mesa")
    fi

    echo -e "${BLUE}Installing drivers: ${DRIVER_PKGS[*]}${NC}"
    sudo pacman -Sy --noconfirm --needed "${DRIVER_PKGS[@]}"

    if [ "$IS_NVIDIA" = true ]; then
        echo -e "${RED}================================================================${NC}"
        echo -e "${RED}⚠️  NVIDIA DKMS INSTALLED! ACTION REQUIRED:                     ${NC}"
        echo -e "${RED}You MUST add the following parameter to your systemd-boot      ${NC}"
        echo -e "${RED}or GRUB kernel parameters line before rebooting:               ${NC}"
        echo -e "${RED}    nvidia-drm.modeset=1                                       ${NC}"
        echo -e "${RED}================================================================${NC}"
    fi
    echo -e "${GREEN}✓ Graphics drivers installed${NC}"
}

# ========================
#  2. Pacman Packages
# ========================
install_pacman_packages() {
    echo -e "${GREEN}[2/6] Installing Pacman packages${NC}"
    
    sudo pacman -Sy --noconfirm
    
    local packages=()
    for category in "${PACMAN_CATEGORIES[@]}"; do
        while IFS= read -r pkg; do
            pkg="${pkg//\"/}" 
            pkg="${pkg//\'/}"
            
            [ -n "$pkg" ] && [ "$pkg" != "null" ] && packages+=("$pkg")
        done < <(get_packages "pacman" "$category")
    done
    
    if [ ${#packages[@]} -gt 0 ]; then
        echo -e "${BLUE}Installing ${#packages[@]} Pacman packages...${NC}"
        sudo pacman -S --noconfirm --needed "${packages[@]}"
        echo -e "${GREEN}✓ Pacman packages installed${NC}"
    else
        echo -e "${YELLOW}No Pacman packages found. Check your packages.yaml${NC}"
    fi
}

# ========================
#  3. AUR Packages
# ========================
install_aur_packages() {
    echo -e "${GREEN}[3/6] Installing AUR packages${NC}"
    if ! command -v yay &> /dev/null; then
        local build_dir="/tmp/yay-build"
        mkdir -p "$build_dir" && cd "$build_dir"
        git clone https://aur.archlinux.org/yay.git && cd yay
        makepkg -si --noconfirm && cd "$HOME" && rm -rf "$build_dir"
    fi
    
    local aur_packages=()
    for category in "${AUR_CATEGORIES[@]}"; do
        while IFS= read -r pkg; do
            pkg="${pkg//\"/}" 
            pkg="${pkg//\'/}"
            
            [ -n "$pkg" ] && [ "$pkg" != "null" ] && aur_packages+=("$pkg")
        done < <(get_packages "aur" "$category")
    done
    
    if [ ${#aur_packages[@]} -gt 0 ]; then
        echo -e "${BLUE}Installing ${#aur_packages[@]} AUR packages...${NC}"
        yay -S --noconfirm --needed "${aur_packages[@]}"
        echo -e "${GREEN}✓ AUR packages installed${NC}"
    else
        echo -e "${YELLOW}No AUR packages found. Check your packages.yaml${NC}"
    fi
}

# ========================
#  4. Metasploit & Postgres Setup
# ========================
setup_security_tools() {
    echo -e "${GREEN}[4/6] Configuring PostgreSQL & Metasploit...${NC}"
    
    if [ ! -d "/var/lib/postgres/data/base" ]; then
        echo -e "${BLUE}Initializing PostgreSQL database...${NC}"
        sudo -u postgres initdb -D /var/lib/postgres/data
    fi

    echo -e "${BLUE}Starting PostgreSQL service...${NC}"
    sudo systemctl start postgresql.service

    echo -e "${BLUE}Initializing Metasploit database (msfdb)...${NC}"
    msfdb init || echo -e "${YELLOW}msfdb init returned non-zero (might already be initialized).${NC}"
    
    echo -e "${GREEN}✓ Metasploit connected to PostgreSQL${NC}"
}

# ========================
#  5. Enable System Services
# ========================
enable_services() {
    echo -e "${GREEN}[5/6] Enabling System Services...${NC}"
    
    sudo systemctl enable bluetooth.service
    sudo systemctl enable greetd.service
    sudo systemctl enable postgresql.service
    sudo systemctl enable xray.service

    systemctl --user enable wireplumber.service
    systemctl --user enable pipewire-pulse.service
    
    echo -e "${GREEN}✓ Services enabled${NC}"
}

# ========================
#  6. Rust
# ========================
install_rust() {
    echo -e "${GREEN}[6/6] Installing Rust (Nightly, Complete Profile)${NC}"
    if [ -d "$HOME/.cargo/bin" ] && [ -f "$HOME/.cargo/bin/rustup" ]; then
        echo -e "${GREEN}✓ Rust already installed. Skipping...${NC}"
        return 0
    fi
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
        --no-modify-path --profile complete --default-toolchain nightly
}

# ========================
#  Main
# ========================
main() {
    echo -e "${CYAN}================================================${NC}"
    echo -e "${CYAN}   Bootstrap Sway + InfoSec Environment         ${NC}"
    echo -e "${CYAN}================================================${NC}"
    
    check_yq
    install_drivers
    install_pacman_packages
    install_aur_packages
    setup_security_tools
    enable_services
    install_rust
    
    echo -e "${GREEN}================================================${NC}"
    echo -e "${GREEN}✓ Bootstrap complete!${NC}"
    echo -e "${BLUE}Log saved to: $LOG_FILE${NC}"
    echo -e "${YELLOW}================================================${NC}"
    echo -e "${YELLOW}⚠️  MANUAL ACTIONS REQUIRED BEFORE REBOOT:       ${NC}"
    echo -e "${YELLOW}1. Edit ${NC}/etc/greetd/config.toml${YELLOW} and change the${NC}"
    echo -e "${YELLOW}   'command' under [default_session] to run Sway:${NC}"
    echo -e "${YELLOW}   e.g., command = \"tuigreet --cmd sway\"       ${NC}"
    echo -e "${YELLOW}2. If you have NVIDIA, check systemd-boot flags! ${NC}"
    echo -e "${YELLOW}================================================${NC}"
}

main

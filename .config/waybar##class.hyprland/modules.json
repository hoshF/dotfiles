{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "format-icons": { "urgent": "ΎΒς ", "active": "ΎΗΤ ", "default": "ΎΕΣ " }
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": { "activated": "ΎΒχ ", "deactivated": "ΎΒ░ " }
  },
  "bluetooth": {
    "format": "{icon}",
    "format-icons": { "enabled": "ΎΛΧ", "disabled": "ΎΨ▓" },
    "on-click": "blueman-manager"
  },
  "pulseaudio": {
    "backend": "pipewire",
    "format": "{icon}",
    "format-muted": "Ύγσ ",
    "tooltip-format": "{icon} {desc} {volume}%",
    "scroll-step": 5,
    "format-icons": {
      "hands-free": "ΎΑξ ",
      "headset": "ΎΑξ ",
      "default": ["ΎΑπ", "ΎΑρ "]
    },
    "on-click": "pavucontrol"
  },
  "network": {
    "tooltip": true,
    "format-wifi": "{icon}",
    "format-icons": ["≤░νθ", "≤░νλ", "≤░νξ"],
    "format-ethernet": "≤░ΙΑ ",
    "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
    "format-linked": "≤░ΙΑ {ifname} (No IP)",
    "format-disconnected": "ΎΒς ",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "alacritty -e nmtui",
    "interval": 2
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon}",
    "format-charging": "<span color='#a6d189'>≤░ΓΕ</span>",
    "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΒ ", "ΎΚΑ "]
  },
  "clock": {
    "format": "{:%I:%M %p }",
    "format-alt": "{:%Y-%m-%d}"
  },
  "hyprland/window": {
    "format": "{}",
    "separator": false,
    "max-length": 50
  }
}
